@page "/EntradaHuacales/Index"
@using Microsoft.AspNetCore.Components.QuickGrid
@rendermode InteractiveServer
@inject NavigationManager navigationManager
@inject EntradasHuacalesServices entradasHuacalesServices

<PageTitle>Registro de Entradas Huacales</PageTitle>

<div class="container mt-4">
    <div class="card shadow-sm border-0">
        <div class="card-header bg-white border-bottom d-flex justify-content-between align-items-center py-3">
            <h5 class="mb-0 text-dark fw-bold">Registro de Entradas Huacales</h5>
            <button class="btn btn-primary btn-sm px-3" @onclick="IrACrear">
                <i class="bi bi-plus-circle me-1"></i> Crear
            </button>
        </div>

        <div class="card-body">
            <div class="row g-3 mb-4">
                <div class="col-md-6">
                    <div class="row">
                        <div class="col-md-6">
                            <label class="form-label small fw-bold">Desde</label>
                            <input type="date" class="form-control form-control-sm" @bind="Desde" />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label small fw-bold">Hasta</label>
                            <input type="date" class="form-control form-control-sm" @bind="Hasta" />
                        </div>
                    </div>
                </div>
                <div class="col-md-3">
                    <label class="form-label small fw-bold">Seleccione una Opción</label>
                    <select class="form-select form-select-sm" @bind="Filtro">
                        <option value="">Seleccione una Opción</option>
                        <option value="NombreCliente">Nombre Cliente</option>
                        <option value="IdEntrada">ID Entrada</option>
                    </select>
                </div>
                <div class="col-md-3">
                    <label class="form-label small fw-bold">Buscar</label>
                    <div class="input-group input-group-sm">
                        <input type="text" class="form-control" @bind="ValorFiltro" placeholder="Buscar..." />
                        <button class="btn btn-primary" @onclick="Buscar">
                            <i class="bi bi-search"></i>
                        </button>
                    </div>
                </div>
            </div>

            <div class="table-responsive">
                <QuickGrid Items="@ListaHuacales.AsQueryable()" Class="table table-hover align-middle mb-0" Pagination="@pagination">
                    <PropertyColumn Property="@(p => p.IdEntrada)" Title="IdEntrada" Sortable="true" />
                    <PropertyColumn Property="@(p => p.Fecha)" Title="Fecha" Sortable="true" Format="dd/MM/yyyy" />
                    <PropertyColumn Property="@(p => p.NombreCliente)" Title="Nombre Cliente" Sortable="true" />
                    
                    <TemplateColumn Title="Opciones">
                        <button class="btn btn-sm btn-outline-primary border-0" @onclick="() => IrAEditar(context.IdEntrada)">
                            <i class="bi bi-pencil-fill"></i>
                        </button>
                    </TemplateColumn>
                </QuickGrid>
            </div>
        </div>

        <div class="card-footer bg-white border-top py-3">
            <div class="d-flex justify-content-between align-items-center">
                <div class="small text-muted">
                    <strong>@ListaHuacales.Count</strong> items
                </div>
                <div class="d-flex align-items-center gap-2">
                    <Paginator State="@pagination" />
                </div>
            </div>
        </div>
    </div>
</div>

@code {
    public string Filtro { get; set; } = string.Empty;
    public string ValorFiltro { get; set; } = string.Empty;
    public DateTime? Desde { get; set; }
    public DateTime? Hasta { get; set; }
    
    public List<EntradasHuacales> ListaHuacales { get; set; } = new();
    PaginationState pagination = new PaginationState { ItemsPerPage = 10 };

    protected override async Task OnInitializedAsync()
    {
        await CargarDatos();
    }

    private async Task CargarDatos()
    {
        ListaHuacales = await entradasHuacalesServices.Listar(en => en.IdEntrada > 0);
    }

    public async Task Buscar()
    {
        if (Desde.HasValue && Hasta.HasValue)
        {
            var fDesde = DateOnly.FromDateTime(Desde.Value);
            var fHasta = DateOnly.FromDateTime(Hasta.Value);
            ListaHuacales = await entradasHuacalesServices.Listar(e => e.Fecha >= fDesde && e.Fecha <= fHasta);
        }
        else if (Filtro == "NombreCliente" && !string.IsNullOrEmpty(ValorFiltro))
        {
            ListaHuacales = await entradasHuacalesServices.Listar(en => en.NombreCliente.ToLower().Contains(ValorFiltro.ToLower()));
        }
        else
        {
            await CargarDatos();
        }
    }

    public void IrACrear() => navigationManager.NavigateTo("/EntradasHuacales/Create");
    private void IrAEditar(int id) => navigationManager.NavigateTo($"/EntradasHuacales/Edit/{id}");
}